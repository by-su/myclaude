# =============================================================================
# MCP 서버 환경변수 템플릿
# =============================================================================
# 사용법:
#   1) 이 파일을 같은 경로에 .env 로 복사
#      cp setup/mcp/.env.example setup/mcp/.env
#   2) 아래 항목을 채운다 (값이 비면 해당 MCP만 SKIP 되고 나머지는 정상 등록)
#   3) 실행
#      sh setup/init/install.sh         # 전체 설치
#      sh setup/mcp/setup-mcp.sh        # MCP만 재등록
#   4) 확인
#      claude mcp list
#
# 주의:
#   - .env 는 절대 커밋하지 말 것 (.gitignore 에 포함 필요)
#   - GitHub MCP 는 docker, 그 외는 npx 가 설치돼 있어야 동작
# =============================================================================


# -----------------------------------------------------------------------------
# GitHub MCP Server
# -----------------------------------------------------------------------------
# 용도 : 이슈/PR/리포 조회·생성, 코드 검색
# 발급 : https://github.com/settings/tokens  →  Generate new token (classic)
# 권장 스코프: repo, read:org, read:user, workflow
# 비워두면: github MCP SKIP
GITHUB_PERSONAL_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Google Docs MCP Server
# -----------------------------------------------------------------------------
# 용도 : Google Docs 문서 읽기/쓰기
# 발급 :
#   1) https://console.cloud.google.com  →  프로젝트 생성
#   2) API 및 서비스  →  사용자 인증 정보  →  OAuth 클라이언트 ID 생성
#   3) 애플리케이션 유형: 데스크톱 앱
#   4) "Google Docs API", "Google Drive API" 활성화
# 비워두면: google-docs MCP SKIP (둘 다 채워야 등록됨)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Context7 MCP Server
# -----------------------------------------------------------------------------
# 용도 : 라이브러리/프레임워크 최신 공식 문서 검색
# 발급 : https://context7.com  로그인  →  Dashboard 에서 API key 생성
# 비워두면: context7 MCP SKIP
CONTEXT7_API_KEY=


# -----------------------------------------------------------------------------
# MySQL MCP Server (선택)
# -----------------------------------------------------------------------------
# 용도 : 로컬/원격 MySQL DB 조회 (읽기 전용 — INSERT/UPDATE/DELETE/DDL 모두 차단됨)
# 사용 시 아래 5줄의 주석(#) 을 풀고 값 입력
# 참고 : MYSQL_DB 를 비우면 모든 DB 접근 가능
#
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASS=
# MYSQL_DB=


# =============================================================================
# 시크릿이 필요 없는 MCP (setup-mcp.sh 가 자동 등록)
#   - figma      : HTTP 방식, Claude 안에서 OAuth 로그인
#   - playwright : 브라우저 자동화
# =============================================================================
