# MCP 서버 환경변수 템플릿
# 이 파일을 같은 경로에 .env 로 복사한 뒤 값을 채워주세요.
# cp setup/mcp/.env.example setup/mcp/.env

# GitHub MCP Server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Google Docs MCP Server
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Context7 MCP Server
CONTEXT7_API_KEY=

# MySQL MCP Server (필요시 주석 해제)
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASS=
# MYSQL_DB= (비워두면 모든 DB 접근 가능)
