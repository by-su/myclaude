{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git status *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(ts-node *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(mvn *)",
      "Bash(kotlin *)",
      "Bash(java *)",
      "Bash(brew *)",
      "Bash(gh *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(source *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "Bash(sudo rm *)",
      "Bash(> /dev/*)"
    ]
  },
  "model": "opus",
  "autoMode": {
    "allow": [
      "$defaults",
      "Installing dependencies via npm, yarn, pnpm, pip is allowed: solo dev, local machine only",
      "Running local dev servers (next dev, uvicorn, spring boot) is allowed",
      "Docker build and docker compose up for local development is allowed"
    ],
    "soft_deny": [
      "$defaults"
    ],
    "hard_deny": [
      "$defaults"
    ],
    "environment": [
      "$defaults",
      "Organization: individual developer (bysu). Primary use: full-stack web development",
      "Source control: github.com/bysu and all repos under it"
    ]
  },
  "skipAutoPermissionPrompt": true
}
